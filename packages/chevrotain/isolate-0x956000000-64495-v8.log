script-source,84,file:///Users/matthew/git/oss/chevrotain/packages/chevrotain/benchmark_web/benchmark.mjs,/**\n * Node.js CLI benchmark for the Chevrotain parser engine.\n *\n * Usage:\n *   node benchmark.mjs                        # our local build\n *   node benchmark.mjs --lib <path>           # compare a different build\n *   node benchmark.mjs --parser json|css      # select parser (default: all)\n *   node benchmark.mjs --cst                  # use CstParser (default: EmbeddedActionsParser)\n *   node benchmark.mjs --iterations 5000      # override iteration count\n *\n * To compare against the published npm version:\n *   npm pack chevrotain@latest -o /tmp/chevrotain-baseline.tgz\n *   tar -xzf /tmp/chevrotain-baseline.tgz -C /tmp/\n *   node benchmark.mjs --lib /tmp/package/lib/chevrotain.mjs\n */\n\nimport { performance } from "node:perf_hooks";\nimport { pathToFileURL } from "node:url";\nimport path from "node:path";\n\n// ---------------------------------------------------------------------------\n// CLI argument parsing\n// ---------------------------------------------------------------------------\nconst args = process.argv.slice(2);\nfunction getArg(flag\x2C defaultVal) {\n  const i = args.indexOf(flag);\n  return i !== -1 ? args[i + 1] : defaultVal;\n}\n\nconst libPath = getArg(\n  "--lib"\x2C\n  new URL("../lib/chevrotain.mjs"\x2C import.meta.url).href\x2C\n);\nconst mode = getArg("--mode"\x2C "warm"); // "warm" | "cold" | "first-parse" | "construction" | "all"\nconst selectedParser = getArg("--parser"\x2C "all");\nconst useCst = args.includes("--cst");\nconst ITERATIONS = parseInt(getArg("--iterations"\x2C "5000")\x2C 10);\nconst WARMUP = Math.max(100\x2C Math.floor(ITERATIONS * 0.1));\n\n// ---------------------------------------------------------------------------\n// Load chevrotain\n// ---------------------------------------------------------------------------\nconst libUrl =\n  libPath.startsWith("http") || libPath.startsWith("file:")\n    ? libPath\n    : pathToFileURL(path.resolve(process.cwd()\x2C libPath)).href;\n\nconst chevrotain = await import(libUrl);\nconst { createToken\x2C Lexer\x2C EmbeddedActionsParser\x2C CstParser } = chevrotain;\nconst ParserBase = useCst ? CstParser : EmbeddedActionsParser;\nconst parserConfig = useCst ? {} : { outputCst: false };\n\n// ---------------------------------------------------------------------------\n// JSON parser\n// ---------------------------------------------------------------------------\nfunction makeJsonParser() {\n  const True = createToken({ name: "True"\x2C pattern: "true" });\n  const False = createToken({ name: "False"\x2C pattern: "false" });\n  const Null = createToken({ name: "Null"\x2C pattern: "null" });\n  const LCurly = createToken({ name: "LCurly"\x2C pattern: "{" });\n  const RCurly = createToken({ name: "RCurly"\x2C pattern: "}" });\n  const LSquare = createToken({ name: "LSquare"\x2C pattern: "[" });\n  const RSquare = createToken({ name: "RSquare"\x2C pattern: "]" });\n  const Comma = createToken({ name: "Comma"\x2C pattern: "\x2C" });\n  const Colon = createToken({ name: "Colon"\x2C pattern: ":" });\n  const StringLiteral = createToken({\n    name: "StringLiteral"\x2C\n    pattern: /"(?:[^\\\\"]|\\\\(?:[bfnrtv"\\\\/]|u[0-9a-fA-F]{4}))*"/\x2C\n  });\n  const NumberLiteral = createToken({\n    name: "NumberLiteral"\x2C\n    pattern: /-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?/\x2C\n  });\n  const WhiteSpace = createToken({\n    name: "WhiteSpace"\x2C\n    pattern: /[ \\n\\r\\t]+/\x2C\n    group: Lexer.SKIPPED\x2C\n  });\n\n  const jsonTokens = [\n    WhiteSpace\x2C\n    StringLiteral\x2C\n    NumberLiteral\x2C\n    Comma\x2C\n    Colon\x2C\n    LCurly\x2C\n    RCurly\x2C\n    LSquare\x2C\n    RSquare\x2C\n    True\x2C\n    False\x2C\n    Null\x2C\n  ];\n\n  const lexer = new Lexer(jsonTokens\x2C { positionTracking: "onlyOffset" });\n\n  class JsonParser extends ParserBase {\n    constructor() {\n      super(jsonTokens\x2C parserConfig);\n\n      const $ = this;\n\n      $.RULE("json"\x2C () => {\n        $.OR([\n          { ALT: () => $.SUBRULE($.object) }\x2C\n          { ALT: () => $.SUBRULE($.array) }\x2C\n        ]);\n      });\n\n      $.RULE("object"\x2C () => {\n        $.CONSUME(LCurly);\n        $.OPTION(() => {\n          $.SUBRULE($.objectItem);\n          $.MANY(() => {\n            $.CONSUME(Comma);\n            $.SUBRULE2($.objectItem);\n          });\n        });\n        $.CONSUME(RCurly);\n      });\n\n      $.RULE("objectItem"\x2C () => {\n        $.CONSUME(StringLiteral);\n        $.CONSUME(Colon);\n        $.SUBRULE($.value);\n      });\n\n      $.RULE("array"\x2C () => {\n        $.CONSUME(LSquare);\n        $.OPTION(() => {\n          $.SUBRULE($.value);\n          $.MANY(() => {\n            $.CONSUME(Comma);\n            $.SUBRULE2($.value);\n          });\n        });\n        $.CONSUME(RSquare);\n      });\n\n      $.RULE("value"\x2C () => {\n        $.OR(\n          ($.c1 ??= [\n            { ALT: () => $.CONSUME(StringLiteral) }\x2C\n            { ALT: () => $.CONSUME(NumberLiteral) }\x2C\n            { ALT: () => $.SUBRULE($.object) }\x2C\n            { ALT: () => $.SUBRULE($.array) }\x2C\n            { ALT: () => $.CONSUME(True) }\x2C\n            { ALT: () => $.CONSUME(False) }\x2C\n            { ALT: () => $.CONSUME(Null) }\x2C\n          ])\x2C\n        );\n      });\n\n      this.performSelfAnalysis();\n    }\n  }\n\n  const parser = new JsonParser();\n\n  // ~40 KB of JSON (1000 records)\n  const sample = JSON.stringify(\n    Array.from({ length: 50 }\x2C (_\x2C i) => ({\n      _id: `id${i}`\x2C\n      index: i\x2C\n      guid: `xxxxxxxx-${i}`\x2C\n      isActive: i % 2 === 0\x2C\n      balance: `$${(1000 + i * 13.37).toFixed(2)}`\x2C\n      name: `Person ${i}`\x2C\n      tags: [`tag${i % 5}`\x2C `tag${(i + 1) % 5}`\x2C `tag${(i + 2) % 5}`]\x2C\n      address: `${i * 100} Main St`\x2C\n      about: `This is a somewhat longer description field for person ${i}.`\x2C\n    }))\x2C\n  );\n\n  return {\n    name: "JSON"\x2C\n    run() {\n      const { tokens } = lexer.tokenize(sample);\n      parser.input = tokens;\n      parser.json();\n    }\x2C\n  };\n}\n\n// ---------------------------------------------------------------------------\n// CSS parser\n// ---------------------------------------------------------------------------\nfunction makeCssParser() {\n  const Identifier = createToken({\n    name: "Identifier"\x2C\n    pattern: /[a-zA-Z]\\w*/\x2C\n  });\n  const Dot = createToken({ name: "Dot"\x2C pattern: "." });\n  const Hash = createToken({ name: "Hash"\x2C pattern: "#" });\n  const Colon = createToken({ name: "Colon"\x2C pattern: ":" });\n  const Semicolon = createToken({ name: "Semicolon"\x2C pattern: ";" });\n  const LCurly = createToken({ name: "LCurly"\x2C pattern: "{" });\n  const RCurly = createToken({ name: "RCurly"\x2C pattern: "}" });\n  const LParen = createToken({ name: "LParen"\x2C pattern: "(" });\n  const RParen = createToken({ name: "RParen"\x2C pattern: ")" });\n  const Comma = createToken({ name: "Comma"\x2C pattern: "\x2C" });\n  const Star = createToken({ name: "Star"\x2C pattern: "*" });\n  const At = createToken({ name: "At"\x2C pattern: "@" });\n  const StringLiteral = createToken({\n    name: "StringLiteral"\x2C\n    pattern: /"[^"]*"|'[^']*'/\x2C\n  });\n  const NumberLiteral = createToken({\n    name: "NumberLiteral"\x2C\n    pattern: /\\d+(\\.\\d+)?(px|em|rem|%|vh|vw|pt)?/\x2C\n  });\n  const WhiteSpace = createToken({\n    name: "WhiteSpace"\x2C\n    pattern: /[ \\t\\n\\r]+/\x2C\n    group: Lexer.SKIPPED\x2C\n  });\n  const Comment = createToken({\n    name: "Comment"\x2C\n    pattern: /\\/\\*[^*]*\\*+([^/*][^*]*\\*+)*\\//\x2C\n    group: Lexer.SKIPPED\x2C\n  });\n  const Other = createToken({ name: "Other"\x2C pattern: /[^\\s{}();:\x2C.#*@"']+/ });\n\n  const cssTokens = [\n    WhiteSpace\x2C\n    Comment\x2C\n    StringLiteral\x2C\n    NumberLiteral\x2C\n    Identifier\x2C\n    LCurly\x2C\n    RCurly\x2C\n    LParen\x2C\n    RParen\x2C\n    Semicolon\x2C\n    Colon\x2C\n    Comma\x2C\n    Dot\x2C\n    Hash\x2C\n    Star\x2C\n    At\x2C\n    Other\x2C\n  ];\n\n  const lexer = new Lexer(cssTokens\x2C { positionTracking: "onlyOffset" });\n\n  class CssParser extends ParserBase {\n    constructor() {\n      super(cssTokens\x2C parserConfig);\n      const $ = this;\n\n      $.RULE("stylesheet"\x2C () => {\n        $.MANY(() => $.SUBRULE($.rule));\n      });\n\n      $.RULE("rule"\x2C () => {\n        $.SUBRULE($.selector);\n        $.CONSUME(LCurly);\n        $.MANY(() => $.SUBRULE($.declaration));\n        $.CONSUME(RCurly);\n      });\n\n      $.RULE("selector"\x2C () => {\n        $.SUBRULE($.selectorPart);\n        $.MANY(() => {\n          $.OPTION(() => $.CONSUME(Comma));\n          $.SUBRULE2($.selectorPart);\n        });\n      });\n\n      $.RULE("selectorPart"\x2C () => {\n        $.AT_LEAST_ONE(() => {\n          $.OR([\n            { ALT: () => $.CONSUME(Identifier) }\x2C\n            { ALT: () => $.CONSUME(Dot) }\x2C\n            { ALT: () => $.CONSUME(Hash) }\x2C\n            { ALT: () => $.CONSUME(Star) }\x2C\n            {\n              ALT: () => {\n                $.CONSUME(Colon);\n                $.CONSUME2(Identifier);\n              }\x2C\n            }\x2C\n          ]);\n        });\n      });\n\n      $.RULE("declaration"\x2C () => {\n        $.CONSUME(Identifier);\n        $.CONSUME(Colon);\n        $.SUBRULE($.value);\n        $.OPTION(() => $.CONSUME(Semicolon));\n      });\n\n      $.RULE("value"\x2C () => {\n        $.AT_LEAST_ONE(() => {\n          $.OR([\n            { ALT: () => $.CONSUME(Identifier) }\x2C\n            { ALT: () => $.CONSUME(NumberLiteral) }\x2C\n            { ALT: () => $.CONSUME(StringLiteral) }\x2C\n            {\n              ALT: () => {\n                $.CONSUME(LParen);\n                $.SUBRULE($.value);\n                $.CONSUME(RParen);\n              }\x2C\n            }\x2C\n            { ALT: () => $.CONSUME(Other) }\x2C\n          ]);\n        });\n      });\n\n      this.performSelfAnalysis();\n    }\n  }\n\n  const parser = new CssParser();\n\n  const sample = Array.from(\n    { length: 100 }\x2C\n    (_\x2C i) => `\n.class${i} {\n  color: red;\n  font-size: 14px;\n  margin: 0;\n  padding: 8px 16px;\n  background-color: white;\n  border: 1px solid #ccc;\n  display: flex;\n  align-items: center;\n}\n.class${i}:hover {\n  color: blue;\n  background-color: #f5f5f5;\n}\n`\x2C\n  ).join("\\n");\n\n  return {\n    name: "CSS"\x2C\n    run() {\n      const { tokens } = lexer.tokenize(sample);\n      parser.input = tokens;\n      parser.stylesheet();\n    }\x2C\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Benchmark runner\n// ---------------------------------------------------------------------------\nconst REPS = 50; // repetitions for construction/cold timing\n\nfunction timeMs(fn\x2C reps = REPS) {\n  fn(); // throwaway: ensure module cached\n  const start = performance.now();\n  for (let i = 0; i < reps; i++) fn();\n  return (performance.now() - start) / reps;\n}\n\nfunction bench(name\x2C fn) {\n  for (let i = 0; i < WARMUP; i++) fn();\n  const start = performance.now();\n  for (let i = 0; i < ITERATIONS; i++) fn();\n  const elapsed = performance.now() - start;\n  const opsPerSec = Math.round((ITERATIONS / elapsed) * 1000);\n  const msPerOp = (elapsed / ITERATIONS).toFixed(3);\n  console.log(\n    `  ${name.padEnd(8)} ${opsPerSec.toLocaleString().padStart(10)} ops/sec   (${msPerOp} ms/op)`\x2C\n  );\n  return opsPerSec;\n}\n\n// ---------------------------------------------------------------------------\n// Main\n// ---------------------------------------------------------------------------\nconst factories = [];\nif (selectedParser === "all" || selectedParser === "json")\n  factories.push({ name: "JSON"\x2C make: makeJsonParser });\nif (selectedParser === "all" || selectedParser === "css")\n  factories.push({ name: "CSS"\x2C make: makeCssParser });\n\nconsole.log(`\\nChevrotain parser benchmark`);\nconsole.log(`  lib:        ${libUrl}`);\nconsole.log(`  parser type: ${useCst ? "CstParser" : "EmbeddedActionsParser"}`);\nconsole.log(`  mode:       ${mode}`);\nconsole.log(\n  `  iterations: ${ITERATIONS.toLocaleString()} (+ ${WARMUP.toLocaleString()} warmup)`\x2C\n);\nconsole.log(`  parsers:    ${factories.map((f) => f.name).join("\x2C ")}\\n`);\n\n// Each mode runs in its own Node process (via --mode flag) to prevent JIT\n// profile pollution between construction-heavy (cold) and parse-heavy (warm) runs.\n// The "all" mode shows all phases for a quick overview.\n\nif (mode === "construction" || mode === "all") {\n  // Time only parser construction (performSelfAnalysis included).\n  // Our engine skips lookahead precomputation; baseline pays that cost here.\n  console.log(`Construction only (${REPS} reps each):`);\n  for (const f of factories) {\n    const ms = timeMs(() => f.make()\x2C REPS);\n    console.log(`  ${f.name.padEnd(8)} ${ms.toFixed(2)} ms`);\n  }\n  console.log();\n}\n\nif (mode === "cold" || mode === "all") {\n  // Time construction + first parse (JIT-cold body).\n  // Fair comparison: a user who creates a parser and immediately parses once.\n  console.log(`Cold (construction + first parse\x2C ${REPS} reps):`);\n  for (const f of factories) {\n    const ms = timeMs(() => {\n      const p = f.make();\n      p.run();\n    }\x2C REPS);\n    console.log(`  ${f.name.padEnd(8)} ${ms.toFixed(2)} ms`);\n  }\n  console.log();\n}\n\nif (mode === "first-parse" || mode === "all") {\n  // Time only the first parse after construction (JIT-cold parse body).\n  // Isolates parse cost from construction cost \u2014 our engine pays zero\n  // lookahead-precomputation overhead here; baseline already paid it during construction.\n  console.log(`First parse only (post-construction\x2C ${REPS} reps):`);\n  for (const f of factories) {\n    const ms =\n      timeMs(() => {\n        const p = f.make();\n        p.run();\n      }\x2C REPS) - timeMs(() => f.make()\x2C REPS);\n    console.log(`  ${f.name.padEnd(8)} ${ms.toFixed(3)} ms`);\n  }\n  console.log();\n}\n\nif (mode === "warm" || mode === "all") {\n  // Steady-state throughput. Parser constructed once\x2C then run ITERATIONS times.\n  // JIT-warm via the WARMUP phase in bench().\n  console.log("Warm (steady-state throughput):");\n  for (const f of factories) {\n    const p = f.make();\n    bench(f.name\x2C () => p.run());\n  }\n  console.log();\n}\n
