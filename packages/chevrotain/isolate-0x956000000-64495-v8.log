script-source,79,node:internal/modules/esm/translators,'use strict';\n\nconst {\n  ArrayPrototypePush\x2C\n  FunctionPrototypeCall\x2C\n  JSONParse\x2C\n  ObjectAssign\x2C\n  ObjectPrototypeHasOwnProperty\x2C\n  ReflectApply\x2C\n  SafeArrayIterator\x2C\n  SafeMap\x2C\n  SafeSet\x2C\n  SafeWeakMap\x2C\n  StringPrototypeIncludes\x2C\n  StringPrototypeReplaceAll\x2C\n  StringPrototypeSlice\x2C\n  StringPrototypeStartsWith\x2C\n  globalThis: { WebAssembly }\x2C\n} = primordials;\n\nconst {\n  compileFunctionForCJSLoader\x2C\n} = internalBinding('contextify');\n\nconst { BuiltinModule } = require('internal/bootstrap/realm');\nconst assert = require('internal/assert');\nconst { readFileSync } = require('fs');\nconst { dirname\x2C extname } = require('path');\nconst {\n  assertBufferSource\x2C\n  loadBuiltinModule\x2C\n  stringify\x2C\n  stripBOM\x2C\n  urlToFilename\x2C\n} = require('internal/modules/helpers');\nconst { stripTypeScriptModuleTypes } = require('internal/modules/typescript');\nconst {\n  kIsCachedByESMLoader\x2C\n  Module: CJSModule\x2C\n  wrapModuleLoad\x2C\n  kModuleSource\x2C\n  kModuleExport\x2C\n  kModuleExportNames\x2C\n  findLongestRegisteredExtension\x2C\n  resolveForCJSWithHooks\x2C\n  loadSourceForCJSWithHooks\x2C\n  populateCJSExportsFromESM\x2C\n} = require('internal/modules/cjs/loader');\nconst { fileURLToPath\x2C pathToFileURL\x2C URL } = require('internal/url');\nlet debug = require('internal/util/debuglog').debuglog('esm'\x2C (fn) => {\n  debug = fn;\n});\nconst { emitExperimentalWarning\x2C kEmptyObject\x2C setOwnProperty\x2C isWindows } = require('internal/util');\nconst {\n  ERR_INVALID_RETURN_PROPERTY_VALUE\x2C\n  ERR_UNKNOWN_BUILTIN_MODULE\x2C\n} = require('internal/errors').codes;\nconst { maybeCacheSourceMap } = require('internal/source_map/source_map_cache');\nconst moduleWrap = internalBinding('module_wrap');\nconst { ModuleWrap } = moduleWrap;\n\n// Lazy-loading to avoid circular dependencies.\nlet getSourceSync;\n/**\n * @param {Parameters<typeof import('./load').getSourceSync>[0]} url\n * @returns {ReturnType<typeof import('./load').getSourceSync>}\n */\nfunction getSource(url) {\n  getSourceSync ??= require('internal/modules/esm/load').getSourceSync;\n  return getSourceSync(url);\n}\n\n/** @type {import('deps/cjs-module-lexer/lexer.js').parse} */\nlet cjsParse;\n/**\n * Initializes the CommonJS module lexer parser using the JavaScript version.\n * TODO(joyeecheung): Use `require('internal/deps/cjs-module-lexer/dist/lexer').initSync()`\n * when cjs-module-lexer 1.4.0 is rolled in.\n */\nfunction initCJSParseSync() {\n  if (cjsParse === undefined) {\n    cjsParse = require('internal/deps/cjs-module-lexer/lexer').parse;\n  }\n}\n\nconst translators = new SafeMap();\nexports.translators = translators;\n\n/**\n * Converts a URL to a file path if the URL protocol is 'file:'.\n * @param {string} url - The URL to convert.\n * @returns {string|URL}\n */\nfunction errPath(url) {\n  const parsed = new URL(url);\n  if (parsed.protocol === 'file:') {\n    return fileURLToPath(parsed);\n  }\n  return url;\n}\n\n// Strategy for loading a standard JavaScript module.\ntranslators.set('module'\x2C function moduleStrategy(url\x2C translateContext\x2C parentURL) {\n  let { source } = translateContext;\n  const isMain = (parentURL === undefined);\n  assertBufferSource(source\x2C true\x2C 'load');\n  source = stringify(source);\n  debug(`Translating StandardModule ${url}`\x2C translateContext);\n  const { compileSourceTextModule } = require('internal/modules/esm/utils');\n  const context = isMain ? { isMain } : undefined;\n  const module = compileSourceTextModule(url\x2C source\x2C this\x2C context);\n  return module;\n});\n\n/**\n * Loads a CommonJS module via the ESM Loader sync CommonJS translator.\n * This translator creates its own version of the `require` function passed into CommonJS modules.\n * Any monkey patches applied to the CommonJS Loader will not affect this module.\n * Any `require` calls in this module will load all children in the same way.\n * @param {import('internal/modules/cjs/loader').Module} module - The module to load.\n * @param {string} source - The source code of the module.\n * @param {string} url - The URL of the module.\n * @param {string} filename - The filename of the module.\n * @param {boolean} isMain - Whether the module is the entrypoint\n */\nfunction loadCJSModule(module\x2C source\x2C url\x2C filename\x2C isMain) {\n  const compileResult = compileFunctionForCJSLoader(source\x2C filename\x2C false /* is_sea_main */\x2C false);\n\n  const { function: compiledWrapper\x2C sourceMapURL\x2C sourceURL } = compileResult;\n  // Cache the source map for the cjs module if present.\n  if (sourceMapURL) {\n    maybeCacheSourceMap(url\x2C source\x2C module\x2C false\x2C sourceURL\x2C sourceMapURL);\n  }\n\n  const cascadedLoader = require('internal/modules/esm/loader').getOrInitializeCascadedLoader();\n  const __dirname = dirname(filename);\n  // eslint-disable-next-line func-name-matching\x2Cfunc-style\n  const requireFn = function require(specifier) {\n    let importAttributes = kEmptyObject;\n    if (!StringPrototypeStartsWith(specifier\x2C 'node:') && !BuiltinModule.normalizeRequirableId(specifier)) {\n      // TODO: do not depend on the monkey-patchable CJS loader here.\n      const path = CJSModule._resolveFilename(specifier\x2C module);\n      switch (extname(path)) {\n        case '.json':\n          importAttributes = { __proto__: null\x2C type: 'json' };\n          break;\n        case '.node':\n          return wrapModuleLoad(specifier\x2C module);\n        default:\n            // fall through\n      }\n      specifier = `${pathToFileURL(path)}`;\n    }\n\n    // FIXME(node:59666) Currently\x2C the ESM loader re-invents require() here for imported CJS and this\n    // requires a separate cache to be populated as well as introducing several quirks. This is not ideal.\n    const job = cascadedLoader.getModuleJobForRequireInImportedCJS(specifier\x2C url\x2C importAttributes);\n    job.runSync();\n    let mod = cjsCache.get(job.url);\n    assert(job.module\x2C `Imported CJS module ${url} failed to load module ${job.url} using require() due to race condition`);\n\n    if (job.module.synthetic) {\n      assert(mod\x2C `Imported CJS module ${url} failed to load module ${job.url} using require() due to missed cache`);\n      return mod.exports;\n    }\n\n    // The module being required is a source text module.\n    if (!mod) {\n      mod = cjsEmplaceModuleCacheEntry(job.url);\n      cjsCache.set(job.url\x2C mod);\n    }\n    // The module has been cached by the re-invented require. Update the exports object\n    // from the namespace object and return the evaluated exports.\n    if (!mod.loaded) {\n      debug('populateCJSExportsFromESM from require(esm) in imported CJS'\x2C url\x2C mod\x2C job.module);\n      populateCJSExportsFromESM(mod\x2C job.module\x2C job.module.getNamespace());\n      mod.loaded = true;\n    }\n    return mod.exports;\n  };\n  setOwnProperty(requireFn\x2C 'resolve'\x2C function resolve(specifier) {\n    if (!StringPrototypeStartsWith(specifier\x2C 'node:')) {\n      const path = CJSModule._resolveFilename(specifier\x2C module);\n      if (specifier !== path) {\n        specifier = `${pathToFileURL(path)}`;\n      }\n    }\n    const { url: resolvedURL } = cascadedLoader.resolveSync(specifier\x2C url\x2C kEmptyObject);\n    return urlToFilename(resolvedURL);\n  });\n  setOwnProperty(requireFn\x2C 'main'\x2C process.mainModule);\n\n  ReflectApply(compiledWrapper\x2C module.exports\x2C\n               [module.exports\x2C requireFn\x2C module\x2C filename\x2C __dirname]);\n  setOwnProperty(module\x2C 'loaded'\x2C true);\n}\n\n// TODO: can we use a weak map instead?\nconst cjsCache = new SafeMap();\n\n/**\n * Creates a ModuleWrap object for a CommonJS module.\n * @param {string} url - The URL of the module.\n * @param {{ format: ModuleFormat\x2C source: ModuleSource }} translateContext Context for the translator\n * @param {string|undefined} parentURL URL of the module initiating the module loading for the first time.\n *   Undefined if it's the entry point.\n * @param {typeof loadCJSModule} [loadCJS] - The function to load the CommonJS module.\n * @returns {ModuleWrap} The ModuleWrap object for the CommonJS module.\n */\nfunction createCJSModuleWrap(url\x2C translateContext\x2C parentURL\x2C loadCJS = loadCJSModule) {\n  debug(`Translating CJSModule ${url}`\x2C translateContext);\n\n  const { format: sourceFormat } = translateContext;\n  let { source } = translateContext;\n  const isMain = (parentURL === undefined);\n  const filename = urlToFilename(url);\n  // In case the source was not provided by the `load` step\x2C we need fetch it now.\n  source = stringify(source ?? getSource(new URL(url)).source);\n\n  const { exportNames\x2C module } = cjsPreparseModuleExports(filename\x2C source\x2C sourceFormat);\n  cjsCache.set(url\x2C module);\n\n  const wrapperNames = [...exportNames];\n  if (!exportNames.has('default')) {\n    ArrayPrototypePush(wrapperNames\x2C 'default');\n  }\n  if (!exportNames.has('module.exports')) {\n    ArrayPrototypePush(wrapperNames\x2C 'module.exports');\n  }\n\n  if (isMain) {\n    setOwnProperty(process\x2C 'mainModule'\x2C module);\n  }\n\n  return new ModuleWrap(url\x2C undefined\x2C wrapperNames\x2C function() {\n    debug(`Loading CJSModule ${url}`);\n\n    if (!module.loaded) {\n      loadCJS(module\x2C source\x2C url\x2C filename\x2C !!isMain);\n    }\n\n    let exports;\n    if (module[kModuleExport] !== undefined) {\n      exports = module[kModuleExport];\n      module[kModuleExport] = undefined;\n    } else {\n      ({ exports } = module);\n    }\n    for (const exportName of exportNames) {\n      if (exportName === 'default' || exportName === 'module.exports' ||\n          !ObjectPrototypeHasOwnProperty(exports\x2C exportName)) {\n        continue;\n      }\n      // We might trigger a getter -> dont fail.\n      let value;\n      try {\n        value = exports[exportName];\n      } catch {\n        // Continue regardless of error.\n      }\n      this.setExport(exportName\x2C value);\n    }\n    this.setExport('default'\x2C exports);\n    this.setExport('module.exports'\x2C exports);\n  }\x2C module);\n}\n\n/**\n * Creates a ModuleWrap object for a CommonJS module without source texts.\n * @param {string} url - The URL of the module.\n * @param {string|undefined} parentURL - URL of the parent module\x2C if any.\n * @returns {ModuleWrap} The ModuleWrap object for the CommonJS module.\n */\nfunction createCJSNoSourceModuleWrap(url\x2C parentURL) {\n  debug(`Translating CJSModule without source ${url}`);\n  const isMain = (parentURL === undefined);\n\n  const filename = urlToFilename(url);\n\n  const module = cjsEmplaceModuleCacheEntry(filename);\n  cjsCache.set(url\x2C module);\n\n  if (isMain) {\n    setOwnProperty(process\x2C 'mainModule'\x2C module);\n  }\n\n  // Addon export names are not known until the addon is loaded.\n  const exportNames = ['default'\x2C 'module.exports'];\n  return new ModuleWrap(url\x2C undefined\x2C exportNames\x2C function evaluationCallback() {\n    debug(`Loading CJSModule ${url}`);\n\n    if (!module.loaded) {\n      wrapModuleLoad(filename\x2C null\x2C isMain);\n    }\n\n    /** @type {import('./loader').ModuleExports} */\n    let exports;\n    if (module[kModuleExport] !== undefined) {\n      exports = module[kModuleExport];\n      module[kModuleExport] = undefined;\n    } else {\n      ({ exports } = module);\n    }\n\n    this.setExport('default'\x2C exports);\n    this.setExport('module.exports'\x2C exports);\n  }\x2C module);\n}\n\ntranslators.set('commonjs-sync'\x2C function requireCommonJS(url\x2C translateContext\x2C parentURL) {\n  initCJSParseSync();\n\n  return createCJSModuleWrap(url\x2C translateContext\x2C parentURL\x2C loadCJSModuleWithModuleLoad);\n});\n\n// Handle CommonJS modules referenced by `require` calls.\n// This translator function must be sync\x2C as `require` is sync.\ntranslators.set('require-commonjs'\x2C (url\x2C translateContext\x2C parentURL) => {\n  initCJSParseSync();\n  assert(cjsParse);\n\n  return createCJSModuleWrap(url\x2C translateContext\x2C parentURL);\n});\n\n// Handle CommonJS modules referenced by `require` calls.\n// This translator function must be sync\x2C as `require` is sync.\ntranslators.set('require-commonjs-typescript'\x2C (url\x2C translateContext\x2C parentURL) => {\n  assert(cjsParse);\n  translateContext.source = stripTypeScriptModuleTypes(stringify(translateContext.source)\x2C url);\n  return createCJSModuleWrap(url\x2C translateContext\x2C parentURL);\n});\n\n// This goes through Module._load to accommodate monkey-patchers.\nfunction loadCJSModuleWithModuleLoad(module\x2C source\x2C url\x2C filename\x2C isMain) {\n  assert(module === CJSModule._cache[filename]);\n  wrapModuleLoad(filename\x2C undefined\x2C isMain);\n}\n\n// Handle CommonJS modules referenced by `import` statements or expressions\x2C\n// or as the initial entry point when the ESM loader handles a CommonJS entry.\ntranslators.set('commonjs'\x2C function commonjsStrategy(url\x2C translateContext\x2C parentURL) {\n  if (!cjsParse) {\n    initCJSParseSync();\n  }\n\n  // For backward-compatibility\x2C it's possible to return a nullish value for\n  // CJS source associated with a `file:` URL - that usually means the source is not\n  // customized (is loaded by default load) or the hook author wants it to be reloaded\n  // through CJS routine. In this case\x2C the source is obtained by calling the\n  // monkey-patchable CJS loader.\n  // TODO(joyeecheung): just use wrapModuleLoad and let the CJS loader\n  // invoke the off-thread hooks. Use a special parent to avoid invoking in-thread\n  // hooks twice.\n  const shouldReloadByCJSLoader = (translateContext.shouldBeReloadedByCJSLoader || translateContext.source == null);\n  const cjsLoader = shouldReloadByCJSLoader ? loadCJSModuleWithModuleLoad : loadCJSModule;\n\n  try {\n    // We still need to read the FS to detect the exports.\n    translateContext.source ??= readFileSync(new URL(url)\x2C 'utf8');\n  } catch {\n    // Continue regardless of error.\n  }\n  return createCJSModuleWrap(url\x2C translateContext\x2C parentURL\x2C cjsLoader);\n});\n\n/**\n * Get or create an entry in the CJS module cache for the given filename.\n * @param {string} filename CJS module filename\n * @param {CJSModule} parent The parent CJS module\n * @returns {CJSModule} the cached CJS module entry\n */\nfunction cjsEmplaceModuleCacheEntry(filename\x2C parent) {\n  // TODO: Do we want to keep hitting the user mutable CJS loader here?\n  let cjsMod = CJSModule._cache[filename];\n  if (cjsMod) {\n    return cjsMod;\n  }\n\n  cjsMod = new CJSModule(filename\x2C parent);\n  cjsMod.filename = filename;\n  cjsMod.paths = CJSModule._nodeModulePaths(cjsMod.path);\n  cjsMod[kIsCachedByESMLoader] = true;\n  CJSModule._cache[filename] = cjsMod;\n\n  return cjsMod;\n}\n\n/**\n * Pre-parses a CommonJS module's exports and re-exports.\n * @param {string} filename - The filename of the module.\n * @param {string} [source] - The source code of the module.\n * @param {string} [format]\n * @returns {{module: CJSModule\x2C exportNames: string[]}}\n */\nfunction cjsPreparseModuleExports(filename\x2C source\x2C format) {\n  const module = cjsEmplaceModuleCacheEntry(filename);\n  if (module[kModuleExportNames] !== undefined) {\n    return { module\x2C exportNames: module[kModuleExportNames] };\n  }\n\n  if (source === undefined) {\n    ({ source } = loadSourceForCJSWithHooks(module\x2C filename\x2C format));\n  }\n  module[kModuleSource] = source;\n\n  debug(`Preparsing exports of ${filename}`);\n  let exports\x2C reexports;\n  try {\n    ({ exports\x2C reexports } = cjsParse(source || ''));\n  } catch {\n    exports = [];\n    reexports = [];\n  }\n\n  const exportNames = new SafeSet(new SafeArrayIterator(exports));\n\n  // Set first for cycles.\n  module[kModuleExportNames] = exportNames;\n\n  // If there are any re-exports e.g. `module.exports = { ...require(...) }`\x2C\n  // pre-parse the dependencies to find transitively exported names.\n  if (reexports.length) {\n    module.filename ??= filename;\n    module.paths ??= CJSModule._nodeModulePaths(dirname(filename));\n\n    for (let i = 0; i < reexports.length; i++) {\n      debug(`Preparsing re-exports of '${filename}'`);\n      const reexport = reexports[i];\n      let resolved;\n      let format;\n      try {\n        ({ format\x2C filename: resolved } = resolveForCJSWithHooks(reexport\x2C module\x2C false));\n      } catch (e) {\n        debug(`Failed to resolve '${reexport}'\x2C skipping`\x2C e);\n        continue;\n      }\n\n      if (format === 'commonjs' ||\n        (!BuiltinModule.normalizeRequirableId(resolved) && findLongestRegisteredExtension(resolved) === '.js')) {\n        const { exportNames: reexportNames } = cjsPreparseModuleExports(resolved\x2C undefined\x2C format);\n        for (const name of reexportNames) {\n          exportNames.add(name);\n        }\n      }\n    }\n  }\n\n  return { module\x2C exportNames };\n}\n\n// Strategy for loading a node builtin CommonJS module that isn't\n// through normal resolution\ntranslators.set('builtin'\x2C function builtinStrategy(url\x2C translateContext) {\n  debug(`Translating BuiltinModule ${url}`\x2C translateContext);\n  // Slice 'node:' scheme\n  const id = StringPrototypeSlice(url\x2C 5);\n  const module = loadBuiltinModule(id\x2C url);\n  cjsCache.set(url\x2C module);\n  if (!StringPrototypeStartsWith(url\x2C 'node:') || !module) {\n    throw new ERR_UNKNOWN_BUILTIN_MODULE(url);\n  }\n  debug(`Loading BuiltinModule ${url}`);\n  return module.getESMFacade();\n});\n\n// Strategy for loading a JSON file\ntranslators.set('json'\x2C function jsonStrategy(url\x2C translateContext) {\n  let { source } = translateContext;\n  assertBufferSource(source\x2C true\x2C 'load');\n  debug(`Loading JSONModule ${url}`);\n  const pathname = StringPrototypeStartsWith(url\x2C 'file:') ?\n    fileURLToPath(url) : null;\n  const shouldCheckAndPopulateCJSModuleCache =\n    // We want to involve the CJS loader cache only for `file:` URL with no search query and no hash.\n    pathname && !StringPrototypeIncludes(url\x2C '?') && !StringPrototypeIncludes(url\x2C '#');\n  let modulePath;\n  let module;\n  if (shouldCheckAndPopulateCJSModuleCache) {\n    modulePath = isWindows ?\n      StringPrototypeReplaceAll(pathname\x2C '/'\x2C '\\\\') : pathname;\n    module = CJSModule._cache[modulePath];\n    if (module?.loaded) {\n      const exports = module.exports;\n      return new ModuleWrap(url\x2C undefined\x2C ['default']\x2C function() {\n        this.setExport('default'\x2C exports);\n      });\n    }\n  }\n  source = stringify(source);\n  if (shouldCheckAndPopulateCJSModuleCache) {\n    // A require call could have been called on the same file during loading and\n    // that resolves synchronously. To make sure we always return the identical\n    // export\x2C we have to check again if the module already exists or not.\n    // TODO: remove CJS loader from here as well.\n    module = CJSModule._cache[modulePath];\n    if (module?.loaded) {\n      const exports = module.exports;\n      return new ModuleWrap(url\x2C undefined\x2C ['default']\x2C function() {\n        this.setExport('default'\x2C exports);\n      });\n    }\n  }\n  try {\n    const exports = JSONParse(stripBOM(source));\n    module = {\n      exports\x2C\n      loaded: true\x2C\n    };\n  } catch (err) {\n    // TODO (BridgeAR): We could add a NodeCore error that wraps the JSON\n    // parse error instead of just manipulating the original error message.\n    // That would allow to add further properties and maybe additional\n    // debugging information.\n    err.message = errPath(url) + ': ' + err.message;\n    throw err;\n  }\n  if (shouldCheckAndPopulateCJSModuleCache) {\n    CJSModule._cache[modulePath] = module;\n  }\n  cjsCache.set(url\x2C module);\n  return new ModuleWrap(url\x2C undefined\x2C ['default']\x2C function() {\n    debug(`Parsing JSONModule ${url}`);\n    this.setExport('default'\x2C module.exports);\n  });\n});\n\n// Strategy for loading a wasm module\n// This logic should collapse into WebAssembly Module Record in future.\n/**\n * @type {WeakMap<\n *   import('internal/modules/esm/utils').ModuleNamespaceObject\x2C\n *   WebAssembly.Instance\n * >} [[Instance]] slot proxy for WebAssembly Module Record\n */\nconst wasmInstances = new SafeWeakMap();\ntranslators.set('wasm'\x2C function(url\x2C translateContext) {\n  const { source } = translateContext;\n  assertBufferSource(source\x2C false\x2C 'load');\n\n  debug(`Translating WASMModule ${url}`\x2C translateContext);\n\n  let compiled;\n  try {\n    compiled = new WebAssembly.Module(source\x2C {\n      builtins: ['js-string']\x2C\n    });\n  } catch (err) {\n    err.message = errPath(url) + ': ' + err.message;\n    throw err;\n  }\n\n  const importsList = new SafeSet();\n  const wasmGlobalImports = [];\n  for (const impt of WebAssembly.Module.imports(compiled)) {\n    if (impt.kind === 'global') {\n      ArrayPrototypePush(wasmGlobalImports\x2C impt);\n    }\n    // Prefix reservations per https://webassembly.github.io/esm-integration/js-api/index.html#parse-a-webassembly-module.\n    if (impt.module.startsWith('wasm-js:')) {\n      throw new WebAssembly.LinkError(`Invalid Wasm import "${impt.module}" in ${url}`);\n    }\n    if (impt.name.startsWith('wasm:') || impt.name.startsWith('wasm-js:')) {\n      throw new WebAssembly.LinkError(`Invalid Wasm import name "${impt.module}" in ${url}`);\n    }\n    importsList.add(impt.module);\n  }\n\n  const exportsList = new SafeSet();\n  const wasmGlobalExports = new SafeSet();\n  for (const expt of WebAssembly.Module.exports(compiled)) {\n    if (expt.kind === 'global') {\n      wasmGlobalExports.add(expt.name);\n    }\n    if (expt.name.startsWith('wasm:') || expt.name.startsWith('wasm-js:')) {\n      throw new WebAssembly.LinkError(`Invalid Wasm export name "${expt.name}" in ${url}`);\n    }\n    exportsList.add(expt.name);\n  }\n\n  const createDynamicModule = require('internal/modules/esm/create_dynamic_module');\n\n  const { module } = createDynamicModule([...importsList]\x2C [...exportsList]\x2C url\x2C (reflect) => {\n    emitExperimentalWarning('Importing WebAssembly module instances');\n    for (const impt of importsList) {\n      const importNs = reflect.imports[impt];\n      const wasmInstance = wasmInstances.get(importNs);\n      if (wasmInstance) {\n        const wrappedModule = ObjectAssign({ __proto__: null }\x2C reflect.imports[impt]);\n        for (const { module\x2C name } of wasmGlobalImports) {\n          if (module !== impt) {\n            continue;\n          }\n          // Import of Wasm module global -> get direct WebAssembly.Global wrapped value.\n          // JS API validations otherwise remain the same.\n          wrappedModule[name] = wasmInstance[name];\n        }\n        reflect.imports[impt] = wrappedModule;\n      }\n    }\n    // In cycles importing unexecuted Wasm\x2C wasmInstance will be undefined\x2C which will fail during\n    // instantiation\x2C since all bindings will be in the Temporal Deadzone (TDZ).\n    const { exports } = new WebAssembly.Instance(compiled\x2C reflect.imports);\n    wasmInstances.set(module.getNamespace()\x2C exports);\n    for (const expt of exportsList) {\n      let val = exports[expt];\n      // Unwrap WebAssembly.Global for JS bindings\n      if (wasmGlobalExports.has(expt)) {\n        try {\n          // v128 will throw in GetGlobalValue\x2C see:\n          // https://webassembly.github.io/esm-integration/js-api/index.html#getglobalvalue\n          val = val.value;\n        } catch {\n          // v128 doesn't support ToJsValue() -> use undefined (ideally should stay in TDZ)\n          continue;\n        }\n      }\n      reflect.exports[expt].set(val);\n    }\n  });\n  // WebAssembly modules support source phase imports\x2C to import the compiled module\n  // separate from the linked instance.\n  module.setModuleSourceObject(compiled);\n  return module;\n});\n\n// Strategy for loading a addon\ntranslators.set('addon'\x2C function translateAddon(url\x2C translateContext\x2C parentURL) {\n  emitExperimentalWarning('Importing addons');\n\n  const { source } = translateContext;\n  // The addon must be loaded from file system with dlopen. Assert\n  // the source is null.\n  if (source !== null) {\n    throw new ERR_INVALID_RETURN_PROPERTY_VALUE(\n      'null'\x2C\n      'load'\x2C\n      'source'\x2C\n      source);\n  }\n\n  debug(`Translating addon ${url}`\x2C translateContext);\n\n  return createCJSNoSourceModuleWrap(url\x2C parentURL);\n});\n\n// Strategy for loading a commonjs TypeScript module\ntranslators.set('commonjs-typescript'\x2C function(url\x2C translateContext\x2C parentURL) {\n  const { source } = translateContext;\n  assertBufferSource(source\x2C true\x2C 'load');\n  debug(`Translating TypeScript ${url}`\x2C translateContext);\n  translateContext.source = stripTypeScriptModuleTypes(stringify(source)\x2C url);\n  return FunctionPrototypeCall(translators.get('commonjs')\x2C this\x2C url\x2C translateContext\x2C parentURL);\n});\n\n// Strategy for loading an esm TypeScript module\ntranslators.set('module-typescript'\x2C function(url\x2C translateContext\x2C parentURL) {\n  const { source } = translateContext;\n  assertBufferSource(source\x2C true\x2C 'load');\n  debug(`Translating TypeScript ${url}`\x2C translateContext);\n  translateContext.source = stripTypeScriptModuleTypes(stringify(source)\x2C url);\n  return FunctionPrototypeCall(translators.get('module')\x2C this\x2C url\x2C translateContext\x2C parentURL);\n});\n
